{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/accounts/*": ["./src/accounts/*"],
      "@/app/*": ["./src/app/*"],
      "@/assets/*": ["./assets/*"],
      "@/config/*": ["./src/config/*"],
      "@/contexts/*": ["./src/contexts/*"],
      "@/dshboard/*": ["./src/dshboard/*"],
      "@/flows/*": ["./src/flows/*"],
      "@/i18n/*": ["./src/i18n/*"],
      "@/modules/*": ["./modules/*"],
      "@/settings/*": ["./src/settings/*"],
      "@/shared/*": ["./src/shared/*"],
      "@/types/*": ["./src/types/*"],
      "@/user-registration/*": ["./src/user-registration/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts", "src/i18n/react-i18next.d.ts"],
  "exclude": ["**/__tests__/**/*", "node_modules"]
}
